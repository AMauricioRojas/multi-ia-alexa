# Nexo IA - variables recomendadas
DATABASE_URL=postgresql://usuario:password@host/database
JWT_SECRET=cambia_esto_por_un_secreto_largo
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Correo: en desarrollo usa console para ver códigos en logs
MAIL_MODE=console
# MAIL_MODE=resend
# RESEND_API_KEY=
# EMAIL_FROM=Nexo IA <no-reply@tudominio.com>

# Admin privado
ADMIN_SECRET=cambia_esto_por_una_clave_larga
# Correos que serán considerados admin al iniciar sesión/crear cuenta, separados por coma
ADMIN_EMAILS=

# Keep alive controlado por admin
PUBLIC_URL=https://multi-ia-alexa-backend.onrender.com
SELF_PING_MINUTES=10

# Correo real con Resend para publicación
# En desarrollo puedes dejar MAIL_MODE=console. Para enviar correo real usa MAIL_MODE=resend.
RESEND_API_KEY=
EMAIL_FROM=Nexo IA <no-reply@tudominio.com>
ADMIN_REPORT_EMAIL=equipo@nexoia.com
